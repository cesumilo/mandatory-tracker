root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_style = space
indent_size = 4
max_line_length = 120

[*.{swift}]
indent_style = space
indent_size = 4

[*.{xml,html,svg}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.gradle.kts]
indent_style = space
indent_size = 4

[*.toml]
indent_style = space
indent_size = 2